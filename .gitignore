# ==========================================
# .gitignore - Archivos a excluir del repositorio
# ==========================================

# Variables de entorno (NUNCA SUBIR)
.env
.env.local
.env.production
.env.development

# Dependencias
node_modules/
__pycache__/
*.pyc

# Builds
.next/
dist/
build/

# Logs
*.log
npm-debug.log*

# Base de datos local
*.db
*.sqlite

# IDE
.vscode/
.idea/
*.swp

# OS
.DS_Store
Thumbs.db