# ==========================================
# ARCHIVO: .env.example
# AUTOR: Pedro Antonio Ramírez Alcántara
# MATERIA: Vinculación Empresarial
# GRUPO: 2007 (2026-II)
# DOCENTE: Aarón Velasco Agustín
# CARRERA: Ingeniería en Computación - FES Aragón
# FUNCIÓN: Variables de entorno - Template para copiar a .env
# ==========================================

# ==========================================
# INSTRUCCIONES:
# ==========================================
# 1. Copiar este archivo a .env
# 2. Reemplazar los valores de ejemplo con los reales
# 3. NUNCA subir .env a GitHub (está en .gitignore)
# 4. Mantener .env.example actualizado con las nuevas variables
#
# Comando para copiar:
# cp .env.example .env

# ==========================================
# BASE DE DATOS (PostgreSQL)
# ==========================================
# URL de conexión a PostgreSQL
# Formato: postgresql://usuario:contraseña@host:puerto/nombre_bd
#
# EJEMPLOS:
# - Local: postgresql://postgres:password@localhost:5432/eduinspect
# - Docker: postgresql://user:pass@db:5432/eduinspect
# - Neon.tech: postgresql://user:pass@ep-something.aws.neon.tech/eduinspect?sslmode=require
#
# NOTA: Si usas Neon.tech, agregar ?sslmode=require al final

DATABASE_URL="postgresql://user:password@localhost:5432/edusync"

# ==========================================
# JWT (Autenticación)
# ==========================================
# SECRET_KEY: Clave secreta para firmar los tokens JWT
# - Muy importante: Usar una clave larga y aleatoria
# - Generar una clave segura con: openssl rand -hex 32
# - En producción, usar una clave diferente a la de desarrollo
#
# ALGORITHM: Algoritmo de encriptación
# - HS256 (recomendado, simétrico)
# - RS256 (asimétrico, requiere par de llaves)
#
# ACCESS_TOKEN_EXPIRE_MINUTES: Tiempo de expiración del token
# - 30 minutos por defecto
# - Ajustar según necesidades de seguridad

SECRET_KEY="tu-secret-key"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ==========================================
# EMAIL / NOTIFICACIONES (Opcional)
# ==========================================
# Configuración para envío de correos electrónicos
# Soporta SendGrid, Resend, SMTP
#
# EMAIL_API_KEY: API Key del servicio de email
# - SendGrid: SG.xxxxxxxxxxxxxx
# - Resend: re_xxxxxxxxxxxxxx
#
# EMAIL_FROM: Dirección de correo del remitente
# - Debe estar verificada en el servicio
#
# Servicios gratuitos:
# - Resend: 3000 emails/mes gratis
# - SendGrid: 100 emails/día gratis

EMAIL_API_KEY="tu-api-key"
EMAIL_FROM="noreply@edusync.com"

# ==========================================
# FRONTEND (Next.js)
# ==========================================
# NOTA: Las variables con NEXT_PUBLIC_ son visibles en el navegador
# No poner secretos aquí
#
# NEXT_PUBLIC_API_URL: URL del backend
# - Desarrollo local: http://localhost:8000
# - Producción: https://api.eduinspect.com
# - Docker: http://backend:8000
#
# Si se deja vacío, el frontend usará rutas relativas (mismo dominio)

# NEXT_PUBLIC_API_URL=""

# ==========================================
# AMBIENTE (Opcional)
# ==========================================
# NODE_ENV: Entorno de ejecución
# - development: desarrollo local
# - production: producción
# - test: pruebas

NODE_ENV="development"

# ==========================================
# LOGS (Opcional)
# ==========================================
# LOG_LEVEL: Nivel de detalle de los logs
# - debug: todos los logs
# - info: logs informativos
# - warning: solo advertencias y errores
# - error: solo errores

LOG_LEVEL="info"

# ==========================================
# CORS (Opcional)
# ==========================================
# Orígenes permitidos para CORS (separados por coma)
# - Desarrollo: http://localhost:3000
# - Producción: https://eduinspect.vercel.app

# CORS_ORIGINS="http://localhost:3000,https://eduinspect.vercel.app"

# ==========================================
# VARIABLES ADICIONALES (Según necesidad)
# ==========================================

# Puerto del servidor backend (opcional, por defecto 8000)
# PORT=8000

# Puerto del servidor frontend (opcional, por defecto 3000)
# NEXT_PUBLIC_PORT=3000

# ==========================================
# GENERACIÓN DE SECRET_KEY SEGURA:
# ==========================================
#
# LINUX/MAC:
# openssl rand -hex 32
#
# WINDOWS (PowerShell):
# [Convert]::ToBase64String([System.Security.Cryptography.RandomNumberGenerator]::GetBytes(32))
#
# WINDOWS (CMD / Git Bash):
# openssl rand -hex 32
#
# ==========================================
# VARIABLES POR ENTORNO:
# ==========================================
#
# DESARROLLO LOCAL:
# DATABASE_URL="postgresql://postgres:admin123@localhost:5432/eduinspect"
# SECRET_KEY="dev-secret-key-12345"
#
# DOCKER COMPOSE:
# DATABASE_URL="postgresql://user:pass@db:5432/eduinspect"
# SECRET_KEY="docker-secret-key-67890"
#
# PRODUCCIÓN (NEON.TECH):
# DATABASE_URL="postgresql://user:pass@ep-something.aws.neon.tech/eduinspect?sslmode=require"
# SECRET_KEY="(generar con openssl rand -hex 32)"
#
# PRODUCCIÓN (VERCEL):
# Configurar en el dashboard de Vercel → Settings → Environment Variables
# NO incluir NEXT_PUBLIC_API_URL para usar rutas relativas
#
# ==========================================
# ARCHIVOS RELACIONADOS:
# ==========================================
#
# - .gitignore: Asegurarse de que .env está incluido
# - docker-compose.yml: Puede referenciar variables de .env
# - next.config.js: Variables NEXT_PUBLIC_* disponibles
#
# ==========================================